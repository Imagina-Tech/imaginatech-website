# ===========================================
# CONFIGURAÇÕES DE AMBIENTE - IMAGINATECH
# ===========================================
# Copie este arquivo para .env e preencha com seus valores
# ===========================================

# Firebase Configuration
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# EmailJS Configuration
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id

# Security
BYPASS_PASSWORD=your_secure_password

# Company
COMPANY_USER_ID=your_company_uid
WHATSAPP_NUMBER=your_whatsapp_number

# URLs
SITE_URL=https://your-domain.com
TRACKING_URL=https://your-domain.com/acompanhar-pedido/

# Parâmetros Configuráveis
MAX_ATTEMPTS=3
TOAST_DURATION=3000
WHATSAPP_FALLBACK_TIMEOUT=500
