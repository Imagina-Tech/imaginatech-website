  ### ESSAS SÃO AS REGRAS APLICADAS NO FIRESTORE BACKEND, ESTÃO AQUI APENAS PARA SEU CONHECIMENTO
  ##rules_version = '2';
  #service cloud.firestore {
    match /databases/{database}/documents {

      function isAdmin() {
        return request.auth != null &&
          request.auth.token.email in [
            "3d3printers@gmail.com",
            "netrindademarcus@gmail.com",
            "quequell1010@gmail.com",
            "igor.butter@gmail.com"
          ];
      }

      function isCompanyAccount() {
        return request.auth != null &&
          request.auth.token.email == "3d3printers@gmail.com";
      }

      function canAccessFinancialData(userId) {
        // Pode acessar se for seus próprios dados OU se for dados da empresa
        return isAdmin() && (
          userId == request.auth.uid ||
          userId == get(/databases/$(database)/documents/systemConfig/companyAccount).data.userId
        );
      }

      // ===========================
      // CONFIGURAÇÃO DO SISTEMA
      // ===========================
      match /systemConfig/{document} {
        allow read: if isAdmin();
        allow write: if isCompanyAccount();
      }

      // Services: qualquer autenticado lê, só admin escreve
      match /services/{document} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
      }

      // Transactions (módulo caixa) - acesso restrito a admins
      match /transactions/{document} {
        allow read, write: if isAdmin();
      }

      // ===========================
      // FINANÇAS PESSOAIS (Multi-usuário)
      // ===========================

      // creditCards (cartões de crédito) - dados pessoais OU da empresa
      match /creditCards/{document} {
        allow create: if isAdmin() &&
          request.resource.data.userId == request.auth.uid;
        allow read: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
        allow update, delete: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
      }

      // cardExpenses (gastos de cartão) - dados pessoais OU da empresa
      match /cardExpenses/{document} {
        allow create: if isAdmin() &&
          request.resource.data.userId == request.auth.uid;
        allow read: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
        allow update, delete: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
      }

      // creditCardPayments (pagamentos de faturas) - dados pessoais OU da empresa
      match /creditCardPayments/{document} {
        allow create: if isAdmin() &&
          request.resource.data.userId == request.auth.uid;
        allow read: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
        allow update, delete: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
      }

      // Subscriptions (assinaturas recorrentes) - dados pessoais OU da empresa
      match /subscriptions/{document} {
        allow create: if isAdmin() &&
          request.resource.data.userId == request.auth.uid;
        allow read: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
        allow update, delete: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
      }

      // Installments (parcelamentos) - dados pessoais OU da empresa
      match /installments/{document} {
        allow create: if isAdmin() &&
          request.resource.data.userId == request.auth.uid;
        allow read: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
        allow update, delete: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
      }

      // Projections (projeções de receita) - dados pessoais OU da empresa
      match /projections/{document} {
        allow create: if isAdmin() &&
          request.resource.data.userId == request.auth.uid;
        allow read: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
        allow update, delete: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
      }

      // Investments (investimentos) - dados pessoais OU da empresa
      match /investments/{document} {
        allow create: if isAdmin() &&
          request.resource.data.userId == request.auth.uid;
        allow read: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
        allow update, delete: if isAdmin() &&
          canAccessFinancialData(resource.data.userId);
      }

      // User Settings (configurações de usuário - metas, limites, data de corte)
      // O ID do documento é o userId, então verificamos o ID do documento
      match /userSettings/{userId} {
        allow read, write: if isAdmin() && canAccessFinancialData(userId);
      }

      // ===========================
      // FIM FINANÇAS PESSOAIS
      // ===========================

      // Tasks (sistema de tarefas) - acesso restrito a admins
      match /tasks/{document} {
        allow read, write: if isAdmin();
      }

      // Admin Access (último acesso dos admins)
      match /adminAccess/{userId} {
        allow read: if isAdmin();
        allow write: if isAdmin() && request.auth.uid == userId;
      }

      // Push tokens (se usar notificações)
      match /pushTokens/{document} {
        allow read, write: if request.auth != null;
      }

      // User orders - histórico de pedidos do cliente
      match /user_orders/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Activity logs - cliente cria, admin gerencia
      match /activity_logs/{document} {
        allow create: if request.auth != null;
        allow read, update, delete: if isAdmin();
      }

      // Clients - admin tem acesso total
      match /clients/{document} {
        allow read, write: if isAdmin();
      }

      // Tracking access - registro de acessos de clientes
      match /tracking_access/{document} {
        allow create: if request.auth != null;
        allow read, update, delete: if isAdmin();
      }

      // Filaments (estoque) - acesso restrito a admins
      match /filaments/{document} {
        allow read, write: if isAdmin();
      }

      // Equipment (inventário) - acesso restrito a admins
      match /equipment/{document} {
        allow read, write: if isAdmin();
      }
    }
  }